{
  "name": "pm-changelog",
  "version": "0.1.0",
  "manifest_version": 2,
  "description": "Generate CHANGELOG.md release notes from pm-cli items",
  "author": "@unbraind",
  "entry": "./dist/extension.js",
  "priority": 50,
  "permissions": {
    "fs_read": true,
    "fs_write": true,
    "process_spawn": true
  },
  "capabilities": [
    "commands",
    "schema"
  ]
}
