{
  "name": "pm-changelog",
  "version": "2026.7.18",
  "manifest_version": 2,
  "description": "Generate CHANGELOG.md release notes from pm-cli items",
  "author": "@unbraind",
  "entry": "./dist/extension.js",
  "priority": 50,
  "pm_min_version": "2026.7.11",
  "trusted": true,
  "sandbox_profile": "none",
  "permissions": {
    "fs_read": true,
    "fs_write": true,
    "network": false,
    "env_read": true,
    "env_write": false,
    "process_spawn": true
  },
  "capabilities": [
    "commands",
    "schema",
    "importers",
    "renderers"
  ],
  "activation": {
    "commands": [
      "changelog generate",
      "changelog export"
    ]
  }
}
