  "npm run changelog:check -- --json",null,project,60,null,null,null,null,null,null,null,null,null,null,null,null
  npm test,null,project,120,null,null,null,null,null,null,null,null,null,null,null,null
close_reason: "Fixed release tag date drift by deriving the default heading date from the existing release tag timestamp; verified npm test and npm run changelog:check -- --json."
body: ""
