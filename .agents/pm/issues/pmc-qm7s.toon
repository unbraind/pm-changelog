  src/generator.ts,project,Assign changelog items to release windows without duplicating ranges
  src/release-context.ts,project,Resolve full-history git release tag windows
  test/generator.test.ts,project,Coverage for git tag windows and release-window assignment
tests[1]{command,path,scope,timeout_seconds,pm_context_mode,env_set,env_clear,shared_host_safe,assert_stdout_contains,assert_stdout_regex,assert_stderr_contains,assert_stderr_regex,assert_stdout_min_lines,assert_json_field_equals,assert_json_field_gte,note}:
  "env -u PM_PATH -u PM_GLOBAL_PATH npm run release:check",null,project,600,null,null,null,null,null,null,null,null,null,null,null,"Package release gate must read the real package tracker for changelog:check"
