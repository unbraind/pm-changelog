{"ts":"2026-05-25T20:06:32.676Z","author":"claude","op":"create","patch":[{"op":"replace","path":"/body","value":"release.yml line 99 has node -e '...' JavaScript that updates manifest.json version and src/extension.ts version literal. Replace with a TypeScript script src/sync-version.ts compiled into dist/sync-version.js and called from the workflow as node dist/sync-version.js <version>."},{"op":"add","path":"/metadata/id","value":"pmc-3qyf"},{"op":"add","path":"/metadata/title","value":"Replace inline node -e JavaScript in daily release workflow with TypeScript helper"},{"op":"add","path":"/metadata/description","value":"release.yml currently embeds inline JavaScript via node -e for version sync across manifest.json and src/extension.ts. The user requires no JavaScript in the package — convert this to a strongly typed TypeScript helper compiled to dist/ and invoked from the workflow."},{"op":"add","path":"/metadata/type","value":"Chore"},{"op":"add","path":"/metadata/status","value":"in_progress"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["cleanup","no-js","release","typescript","workflow"]},{"op":"add","path":"/metadata/created_at","value":"2026-05-25T20:06:32.676Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-05-25T20:06:32.676Z"},{"op":"add","path":"/metadata/deadline","value":"2026-05-26T20:06:32.676Z"},{"op":"add","path":"/metadata/assignee","value":"claude"},{"op":"add","path":"/metadata/author","value":"claude"},{"op":"add","path":"/metadata/estimated_minutes","value":45},{"op":"add","path":"/metadata/acceptance_criteria","value":"release.yml contains no inline node -e JavaScript; version sync runs from a compiled TypeScript helper that reads NPM_VERSION env and updates manifest.json + extension.ts deterministically; tests cover the new helper."},{"op":"add","path":"/metadata/value","value":"Aligns release automation with the package's strict TypeScript policy."},{"op":"add","path":"/metadata/impact","value":"Reduces drift risk between manifest, extension, and package version; one canonical mechanism."},{"op":"add","path":"/metadata/outcome","value":"release.yml passes lint with TypeScript helper handling version sync"},{"op":"add","path":"/metadata/why_now","value":"Surfaced during 2026-05-25 readiness audit."},{"op":"add","path":"/metadata/parent","value":"pmc-9mck"},{"op":"add","path":"/metadata/reviewer","value":"claude"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"pmc-typescript@6.0.3","kind":"related","created_at":"2026-05-25T20:06:32.676Z"}]},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-05-25T20:06:32.676Z","author":"claude","text":"Identified inline JS in .github/workflows/release.yml step 'Update release version'."}]},{"op":"add","path":"/metadata/notes","value":[{"created_at":"2026-05-25T20:06:32.676Z","author":"claude","text":"Implement under src/sync-version.ts as a strictly typed top-level script."}]},{"op":"add","path":"/metadata/learnings","value":[{"created_at":"2026-05-25T20:06:32.676Z","author":"claude","text":"Workflow steps that mutate package metadata should live as compiled TypeScript helpers, not inline node -e expressions."}]},{"op":"add","path":"/metadata/files","value":[{"path":".github/workflows/release.yml","scope":"project"},{"path":"src/sync-version.ts","scope":"project"},{"path":"manifest.json","scope":"project"},{"path":"src/extension.ts","scope":"project"}]},{"op":"add","path":"/metadata/tests","value":[{"command":"npm run check","scope":"project"}]},{"op":"add","path":"/metadata/docs","value":[{"path":"docs/release.md","scope":"project"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"25ede64a4bbca189c039216be03a5891f28f34d8b141ab0d6a3efd2d45199f69","message":"Open chore to remove inline JS from release workflow"}
