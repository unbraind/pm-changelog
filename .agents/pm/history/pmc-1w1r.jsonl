{"ts":"2026-06-03T05:47:51.483Z","author":"codex","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pmc-1w1r"},{"op":"add","path":"/metadata/title","value":"Zero-regression guarantee for pm-changelog enhancements"},{"op":"add","path":"/metadata/description","value":"All new flags (--section-by, --conventional, --contributors, --limit, --since-version, --changelog-json) are strictly additive and opt-in. With no new flags, every existing invocation (replace, --check, --stdout, --github-step-summary, --json) is byte-identical to published 2026.6.2. Verified by diffing a pristine baseline build against the new build across 9 modes on a real pm fixture (all PASS), exit-code contract preserved (check clean=0/dirty=1), help text additive-only, and an e2e CLI regression test pinned to a recorded baseline string. Every sibling package's release workflow depends on this."},{"op":"add","path":"/metadata/type","value":"Decision"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":[]},{"op":"add","path":"/metadata/created_at","value":"2026-06-03T05:47:51.483Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-03T05:47:51.483Z"},{"op":"add","path":"/metadata/author","value":"codex"},{"op":"add","path":"/metadata/parent","value":"pmc-emx6"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"5721c1d86e3af8c6b6f508a70817d4d89825f01f9cbc4ab44e0b14927946d89f","message":"Record zero-regression guarantee"}
