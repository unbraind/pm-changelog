{"ts":"2026-06-03T12:41:24.993Z","author":"codex-active-sdk-cli","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/1","value":{"created_at":"2026-06-03T12:41:24.993Z","author":"codex-active-sdk-cli","text":"Review follow-up: Gemini flagged malformed label inputs. Added defensive label normalization so --section-by label ignores non-string tags and treats non-array tag fields as Unlabeled, with regression coverage. Verification: npm test; npm run changelog:full && npm run changelog:check."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-06-03T12:41:24.993Z"}],"before_hash":"cf2ed965e22b58569b64784a92bb8dd8cfa1be0e1260a3c4f4b0c851e2dd0e9a","after_hash":"5a2c42af3c722b198fc2b3224ae9215be46c4478ba8e1b79d9efe21435ce6e3d"}
