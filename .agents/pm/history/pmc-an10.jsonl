{"ts":"2026-06-03T11:45:14.316Z","author":"codex-pm-changelog-fix","op":"comment_add","patch":[{"op":"replace","path":"/metadata/updated_at","value":"2026-06-03T11:45:14.316Z"},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-06-03T11:45:14.316Z","author":"codex-pm-changelog-fix","text":"Evidence: Verified Gemini review finding from pm-cli PR #105 in upstream pm-changelog. groupByField(..., sectionBy=label) iterated raw trimmed tags, so duplicate tags on one item could render duplicate bullets under the same label heading. Fixed by deduplicating normalized tags per item with Set and added regression coverage. Verification passed: npm test (64 tests)."}]}],"before_hash":"102cadea9aabe0a277877dc011a19f904b69a5ae1bc4c01df5479ca4f56ebb01","after_hash":"7f241af325175101af7f7174c7771c7311783a23fae5ef303ec1caa9e3801160"}
